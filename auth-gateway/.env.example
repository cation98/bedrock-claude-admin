# Auth Gateway 환경변수

# Database (플랫폼 자체 DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bedrock_claude

# JWT
JWT_SECRET_KEY=change-me-in-production-use-256-bit-secret

# SSO (sso.skons.net)
SSO_AUTH_URL=https://sso.skons.net/auth
SSO_AUTH_URL2=https://sso.skons.net/userinfo
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
PW_ENCODING_SALT=

# Kubernetes
K8S_IN_CLUSTER=false
K8S_NAMESPACE=claude-sessions
K8S_POD_IMAGE=ACCOUNT_ID.dkr.ecr.ap-northeast-2.amazonaws.com/bedrock-claude/claude-code-terminal:latest
K8S_SERVICE_ACCOUNT=claude-terminal-sa

# Bedrock (Pod에 주입)
BEDROCK_REGION=us-east-1
BEDROCK_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
BEDROCK_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# RDS ReadOnly Replica (Pod에 주입)
WORKSHOP_DATABASE_URL=postgresql://readonly_user:password@rds-endpoint:5432/safety_db
