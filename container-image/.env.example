# AWS Credentials (STS 임시 자격증명 또는 IAM 키)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# RDS ReadOnly Replica 접속 URL
DATABASE_URL=postgresql://readonly_user:password@your-rds-endpoint:5432/safety_db

# Git 설정
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.id@skons.net
