#!/bin/bash
# Block push to anywhere except Gitea internal server
set -euo pipefail

remote_name="$1"
remote_url="$2"

# git insteadOf rewrites external URL to internal cluster DNS before hook is called.
# Both forms must be allowed.
ALLOWED_EXTERNAL="https://gitea.internal.skons.net/"
ALLOWED_INTERNAL="http://gitea-http.gitea.svc.cluster.local:3000/"

if [[ "$remote_url" != "$ALLOWED_EXTERNAL"* && "$remote_url" != "$ALLOWED_INTERNAL"* ]]; then
  echo "❌ Push blocked: remote URL ($remote_url) is not Gitea (gitea.internal.skons.net)."
  echo "   External git push is prohibited by platform policy."
  echo "   Configure remote to use Gitea: git remote set-url origin https://gitea.internal.skons.net/<your-id>/<repo>.git"
  exit 1
fi

exit 0
