{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "/home/node/.claude/hooks/security-hook.sh",
        "timeout": 5000
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1"
  },
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(psql *)",
      "Bash(aws *)",
      "Bash(npm *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(sort *)",
      "Bash(uvicorn *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(socat *)",
      "Bash(ssh *)",
      "Bash(scp *)"
    ]
  }
}
