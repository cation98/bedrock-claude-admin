#!/usr/bin/env python3
"""secure-put — 민감 파일을 S3 Vault에 업로드.

Usage:
    secure-put <file> [--ttl <days>] [--type sensitive|normal]

Examples:
    secure-put salary.csv
    secure-put hr_data.xlsx --ttl 14
    secure-put report.pdf --type normal --ttl 30

Environment:
    GATEWAY_URL      auth-gateway URL (default: http://auth-gateway:8000)
    SECURE_POD_TOKEN Pod authentication token
    POD_NAME         Pod name for authentication
"""

import os
import sys
import json
import base64
import argparse
import urllib.request
import urllib.error


def main():
    parser = argparse.ArgumentParser(description="Upload sensitive file to S3 Vault")
    parser.add_argument("file", help="File to upload")
    parser.add_argument("--ttl", type=int, default=7, help="Retention days (default: 7)")
    parser.add_argument("--type", dest="file_type", choices=["sensitive", "normal"],
                        default="sensitive", help="Classification (default: sensitive)")
    args = parser.parse_args()

    if not os.path.isfile(args.file):
        print(json.dumps({"error": f"File not found: {args.file}"}), file=sys.stderr)
        sys.exit(2)

    gateway_url = os.environ.get("GATEWAY_URL", "http://auth-gateway:8000")
    pod_token = os.environ.get("SECURE_POD_TOKEN", "")
    pod_name = os.environ.get("POD_NAME", "")

    if not pod_token or not pod_name:
        print(json.dumps({"error": "SECURE_POD_TOKEN and POD_NAME environment variables required"}), file=sys.stderr)
        sys.exit(1)

    # Read file and encode as base64 for JSON transport
    with open(args.file, "rb") as f:
        file_data = base64.b64encode(f.read()).decode()

    filename = os.path.basename(args.file)
    payload = json.dumps({
        "filename": filename,
        "file_data_b64": file_data,
        "ttl_days": args.ttl,
        "classification": args.file_type,
    }).encode()

    url = f"{gateway_url}/api/v1/secure/put"
    req = urllib.request.Request(url, data=payload, headers={
        "Content-Type": "application/json",
        "X-Pod-Name": pod_name,
        "X-Pod-Token": pod_token,
    })

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
            print(json.dumps(result))
            sys.exit(0)
    except urllib.error.HTTPError as e:
        error_body = e.read().decode() if e.fp else str(e)
        print(json.dumps({"error": f"Upload failed ({e.code})", "detail": error_body}), file=sys.stderr)
        sys.exit(1 if e.code == 403 else 2)
    except Exception as e:
        print(json.dumps({"error": str(e)}), file=sys.stderr)
        sys.exit(2)


if __name__ == "__main__":
    main()
