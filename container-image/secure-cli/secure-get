#!/usr/bin/env python3
"""secure-get — S3 Vault에서 파일을 임시 복호화.

Usage:
    secure-get <vault_id> [--duration <minutes>]

Examples:
    secure-get abc123def456
    secure-get abc123def456 --duration 30

Output (stdout):
    {"path": "/tmp/secure/abc123/salary.csv", "expires_in": 3600}

The file is written to /tmp/secure/<vault_id>/ and auto-deleted after expiry.

Environment:
    GATEWAY_URL      auth-gateway URL (default: http://auth-gateway:8000)
    SECURE_POD_TOKEN Pod authentication token
    POD_NAME         Pod name for authentication
"""

import os
import sys
import json
import base64
import argparse
import urllib.request
import urllib.error

SECURE_DIR = "/tmp/secure"


def main():
    parser = argparse.ArgumentParser(description="Retrieve file from S3 Vault")
    parser.add_argument("vault_id", help="Vault ID from secure-put output")
    parser.add_argument("--duration", type=int, default=60, help="Minutes to keep file (default: 60)")
    args = parser.parse_args()

    gateway_url = os.environ.get("GATEWAY_URL", "http://auth-gateway:8000")
    pod_token = os.environ.get("SECURE_POD_TOKEN", "")
    pod_name = os.environ.get("POD_NAME", "")

    if not pod_token or not pod_name:
        print(json.dumps({"error": "SECURE_POD_TOKEN and POD_NAME required"}), file=sys.stderr)
        sys.exit(1)

    # Request file from vault
    payload = json.dumps({
        "vault_id": args.vault_id,
        "duration_minutes": args.duration,
    }).encode()

    url = f"{gateway_url}/api/v1/secure/get"
    req = urllib.request.Request(url, data=payload, headers={
        "Content-Type": "application/json",
        "X-Pod-Name": pod_name,
        "X-Pod-Token": pod_token,
    })

    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            result = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(json.dumps({"error": f"Retrieval failed ({e.code})"}), file=sys.stderr)
        sys.exit(1 if e.code == 403 else 2)
    except Exception as e:
        print(json.dumps({"error": str(e)}), file=sys.stderr)
        sys.exit(2)

    # Decode and write file
    filename = result.get("filename", "unknown")
    content_b64 = result.get("content_b64", "")

    vault_dir = os.path.join(SECURE_DIR, args.vault_id)
    os.makedirs(vault_dir, mode=0o700, exist_ok=True)

    file_path = os.path.join(vault_dir, filename)
    with open(file_path, "wb") as f:
        f.write(base64.b64decode(content_b64))
    os.chmod(file_path, 0o600)

    expires_in = args.duration * 60
    print(json.dumps({"path": file_path, "expires_in": expires_in}))

    # Schedule cleanup (at command or background process)
    _schedule_cleanup(vault_dir, args.duration)
    sys.exit(0)


def _schedule_cleanup(vault_dir: str, minutes: int):
    """Schedule auto-deletion of temp files."""
    try:
        # Use 'at' command if available
        import subprocess
        cmd = f'rm -rf "{vault_dir}"'
        proc = subprocess.Popen(
            ["at", f"now + {minutes} minutes"],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE
        )
        proc.communicate(input=cmd.encode())
    except Exception:
        # Fallback: write a marker file for cron cleanup
        marker = os.path.join(vault_dir, ".expires")
        import time
        with open(marker, "w") as f:
            f.write(str(int(time.time()) + minutes * 60))


if __name__ == "__main__":
    main()
