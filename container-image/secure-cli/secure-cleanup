#!/usr/bin/env python3
"""secure-cleanup — 만료된 임시 복호화 파일 정리. cron에서 1분마다 실행."""

import os
import sys
import shutil
import time

SECURE_DIR = "/tmp/secure"


def main():
    if not os.path.isdir(SECURE_DIR):
        return
    now = int(time.time())
    for vault_id in os.listdir(SECURE_DIR):
        vault_dir = os.path.join(SECURE_DIR, vault_id)
        if not os.path.isdir(vault_dir):
            continue
        marker = os.path.join(vault_dir, ".expires")
        if os.path.isfile(marker):
            with open(marker) as f:
                try:
                    expires = int(f.read().strip())
                except ValueError:
                    expires = 0
            if now >= expires:
                shutil.rmtree(vault_dir, ignore_errors=True)
                print(f"[secure-cleanup] Removed expired vault: {vault_id}")


if __name__ == "__main__":
    main()
