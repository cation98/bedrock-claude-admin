# Template for auth-gateway-secrets.
# Copy to secrets.yaml and fill in real values before applying.
#   cp secrets.yaml.example secrets.yaml
#   vim secrets.yaml            # fill in values
#   kubectl apply -f secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: auth-gateway-secrets
  namespace: platform
type: Opaque
stringData:
  JWT_SECRET_KEY: "<CHANGE_ME>"            # Random 256-bit key for JWT signing
  SSO_AUTH_URL: "<CHANGE_ME>"              # sso.skons.net token endpoint
  SSO_AUTH_URL2: "<CHANGE_ME>"             # sso.skons.net userinfo endpoint
  SSO_CLIENT_ID: "<CHANGE_ME>"             # SSO OAuth client ID
  SSO_CLIENT_SECRET: "<CHANGE_ME>"         # SSO OAuth client secret
  PW_ENCODING_SALT: "<CHANGE_ME>"          # SHA-256 password encoding salt (Base64)
  DATABASE_URL: "<CHANGE_ME>"              # Platform PostgreSQL connection string
  WORKSHOP_DATABASE_URL: "<CHANGE_ME>"     # RDS read-only replica for workshop
  TANGO_DATABASE_URL: "<CHANGE_ME>"        # RDS read-only replica for TANGO
