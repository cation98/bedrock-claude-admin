# =============================================================================
# Secret: RDS 접속 정보
#
# Secret = K8s에서 비밀번호, API 키 등 민감 정보를 저장하는 객체
# Pod의 환경변수로 자동 주입됨
#
# 사용법:
#   1. 이 파일을 rds-secret.yaml로 복사
#   2. 실제 DB URL을 base64 인코딩하여 입력
#   3. kubectl apply -f rds-secret.yaml
#
# base64 인코딩 방법:
#   echo -n "postgresql://user:pass@host:5432/db" | base64
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: rds-credentials
  namespace: claude-sessions
type: Opaque
data:
  # base64 encoded: postgresql://readonly_user:password@rds-endpoint:5432/safety_db
  database-url: cG9zdGdyZXNxbDovL3JlYWRvbmx5X3VzZXI6cGFzc3dvcmRAcmRzLWVuZHBvaW50OjU0MzIvc2FmZXR5X2Ri
