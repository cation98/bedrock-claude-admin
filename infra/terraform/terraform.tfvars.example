# =============================================================================
# Terraform 변수 값 설정
# 이 파일을 terraform.tfvars로 복사하여 실제 값을 입력하세요.
# terraform.tfvars는 .gitignore에 포함되어 있어 커밋되지 않습니다.
# =============================================================================

aws_region  = "ap-northeast-2"
environment = "dev"

# EKS 노드 설정
# Phase 1 (15명): m5.large × 2
# Phase 2 (50명): m5.xlarge × 4로 변경
eks_node_instance_types = ["m5.large"]
eks_node_desired_size   = 2
eks_node_min_size       = 2
eks_node_max_size       = 4

# Bedrock 리전 (Claude 모델이 있는 리전)
bedrock_region = "us-east-1"
